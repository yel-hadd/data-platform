# For local use without Docker: change localhost:5432 to localhost:5433 if Docker Compose is running
# For use inside Docker Compose: set to postgresql+asyncpg://pipeline:pipeline@postgres:5432/dataplatform
DATABASE_URL=postgresql+asyncpg://pipeline:pipeline@localhost:5433/dataplatform
LOG_LEVEL=INFO
DATA_DIR=data/raw
CHUNK_SIZE=10000
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EXTRACTION_MODEL=openai:gpt-4o-mini
